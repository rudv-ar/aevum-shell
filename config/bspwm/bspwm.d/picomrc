#!/bin/bash
#  ╔═╗╦╔═╗╔═╗╔╦╗  ╔═╗╔═╗╔╗╔╔═╗╦╔═╗
#  ╠═╝║║  ║ ║║║║  ║  ║ ║║║║╠╣ ║║ ╦
#  ╩  ╩╚═╝╚═╝╩ ╩  ╚═╝╚═╝╝╚╝╚  ╩╚═╝
#
#  RUDV-AR - 2026
#  generate.sh — sources picom-settings.sh, builds picom.conf, restarts picom
#  Usage: ./generate.sh
#  Set as toml-gui reload command: $HOME/.config/picom/generate.sh

PICOM_DIR="$HOME/.config/bspwm/bspwm.d/picom"

source "$PICOM_DIR/picom-settings.sh"

bool() { [ "$1" = "true" ] && echo true || echo false; }

cat > "$PICOM_DIR/picom.conf" << EOF
#  ╔═╗╦╔═╗╔═╗╔╦╗  ╔═╗╔═╗╔╗╔╔═╗╦╔═╗
#  ╠═╝║║  ║ ║║║║  ║  ║ ║║║║╠╣ ║║ ╦
#  ╩  ╩╚═╝╚═╝╩ ╩  ╚═╝╚═╝╝╚╝╚  ╩╚═╝
#
#  RUDV-AR - 2026
#  Generated by toml-gui — do not edit manually
#  Source: $PICOM_DIR/picom.toml
##################################################################

#################################
#             Shadows           #
#################################
shadow = $is_picom_shadows;
shadow-radius   = $picom_shadows_radius;
shadow-opacity  = $picom_shadows_opacity;
shadow-offset-x = $picom_shadows_offset_x;
shadow-offset-y = $picom_shadows_offset_y;
shadow-color    = "$picom_shadows_color";

#################################
#             Blur              #
#################################
blur-background       = $(bool "$is_picom_blur");
blur-method           = "$picom_blur_method";
blur-size             = $picom_blur_size;
blur-deviation        = $picom_blur_deviation;
blur-strength         = $picom_blur_strength;
blur-background-frame = $(bool "$picom_blur_background_frame");
blur-background-fixed = $(bool "$picom_blur_background_fixed");

#################################
#             Fading            #
#################################
fading                   = $(bool "$is_picom_fading");
fade-in-step             = $picom_fading_in_step;
fade-out-step            = $picom_fading_out_step;
fade-delta               = $picom_fading_delta;
no-fading-openclose      = $(bool "$picom_fading_no_fading_openclose");
no-fading-destroyed-argb = $(bool "$picom_fading_no_fading_destroyed_argb");

#################################
#             Corners           #
#################################
corner-radius = $picom_corners_radius;

#################################
#       General Settings        #
#################################
backend                = "$picom_general_backend";
vsync                  = $(bool "$picom_general_vsync");
dithered-present       = $(bool "$picom_general_dithered_present");
use-damage             = $(bool "$picom_general_use_damage");
detect-rounded-corners = $(bool "$picom_general_detect_rounded_corners");
detect-client-opacity  = $(bool "$picom_general_detect_client_opacity");
detect-transient       = $(bool "$picom_general_detect_transient");
log-level              = "$picom_general_log_level";

EOF

# Append static window rules + animations include
cat "$PICOM_DIR/rules.conf" >> "$PICOM_DIR/picom.conf"

# Restart picom
pkill -x picom 2>/dev/null
sleep 0.1
picom --config "$PICOM_DIR/picom.conf" &

echo "picom restarted — $PICOM_DIR/picom.conf"
